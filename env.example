# ===========================================
# LLM AGENT FILESYSTEM TOOLS
# ===========================================
# Enable LLM filesystem tools for direct file operations
# When enabled, LLM can read/write/list/search/delete files via tool calls
#
# ⚠️ SECURITY WARNING: Only enable in trusted environments with proper auth
# - Requires authentication (userId) for tool execution
# - Should be used with sandboxing/isolation in production
# - Enable only if your use case requires filesystem access
# - Keep disabled by default for security (opt-in only)
#
# Production recommendations:
# - Use with proper authentication middleware
# - Run in sandboxed/containerized environment
# - Implement rate limiting and audit logging
# - Restrict file access to specific directories

LLM_AGENT_TOOLS_ENABLED=true
LLM_AGENT_TOOLS_MAX_ITERATIONS=10
LLM_AGENT_TOOLS_TIMEOUT_MS=30000

# ===========================================
# SANDBOX IDLE TIMEOUT
# ===========================================
# Auto-disconnect sandbox after period of inactivity
# Set to 0 to disable idle timeout

SANDBOX_IDLE_TIMEOUT_MS=900000
SANDBOX_IDLE_WARNING_MS=60000

# ===========================================
# REFLECTION ENGINE
# ===========================================

FAST_AGENT_REFLECTION_THREADS=3
FAST_AGENT_REFLECTION_THRESHOLD=0.8
FAST_AGENT_REFLECTION_TIMEOUT=15000

