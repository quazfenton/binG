#
#

# CORS Proxy for downloading images from external blob storage (optional)
# Used for image generation downloads when direct fetch fails due to CORS
# You can use a public CORS proxy or self-host one (e.g., cors-anywhere)
# Example: https://corsproxy.io/?url= or http://localhost:8080/?url=
# NEXT_PUBLIC_CORS_PROXY_URL=https://corsproxy.io/?url=

# Notion OAuth
#NOTION_CLIENT_ID=your_notion_client_id
#NOTION_CLIENT_SECRET=your_notion_client_secret
#NOTION_REDIRECT_URI=http://localhost:3000/api/oauth/notion/callback

# ===========================================
# NEXTCLOUD INTEGRATION
# ===========================================

NEXTCLOUD_URL=https://your-nextcloud-instance.com
NEXTCLOUD_USERNAME=your_nextcloud_username
NEXTCLOUD_PASSWORD=your_nextcloud_password


# ===========================================
# UNIFIED AGENT MODES (V1 vs V2)
# ===========================================

# The unified agent system supports two modes:
# 
# V1: LLM Chat API (Default)
#   - Uses cloud LLM APIs (Mistral, Google, OpenRouter, OpenCode API, etc.)
#   - Fast, no sandbox required
#   - Set LLM_PROVIDER to your preferred API provider
#
# V2: OpenCode Containerized
#   - Runs opencode CLI in isolated sandbox
#   - Better for complex code tasks with tool execution
#   - Requires SANDBOX_PROVIDER configured
#
# To use V2 mode:
#   1. Set LLM_PROVIDER=opencode
#   2. Set OPENCODE_CONTAINERIZED=true  
#   3. Configure SANDBOX_PROVIDER with API key
#
# To use V1 mode (default):
#   1. Set LLM_PROVIDER=mistral (or google, openrouter, etc.)
#   2. Set appropriate API key (MISTRAL_API_KEY, etc.)
#   3. OPENCODE_CONTAINERIZED=false or not set

# V2 feature flag (route /api/chat to V2 when agentMode=auto)
V2_AGENT_ENABLED=true

# MCP for V2 (OpenCode CLI discovery)
MCP_ENABLED=true
MCP_CLI_PORT=8888
#MCP_CLI_AUTH_TOKEN=your_mcp_cli_token_here

# ===========================================
# NULLCLAW INTEGRATION (Non-Coding Agency)
# ===========================================
# Nullclaw provides messaging, browsing, and automation capabilities
# Supports both URL-based (external service) and container-based deployment

# Enable Nullclaw integration
NULLCLAW_ENABLED=true

# Primary: URL-based mode (recommended for production)
# Set this to use an external Nullclaw service (docker-compose, cloud, etc.)
# NULLCLAW_URL=http://nullclaw:3000

# Optional: API key for authentication (if required by your Nullclaw service)
# NULLCLAW_API_KEY=your_nullclaw_api_key

# Fallback: Container-based mode (development/local)
# Container sharing mode: 'shared' (pool) or 'per-session' (dedicated)
NULLCLAW_MODE=shared

# Container pool size (for shared mode, default: 2, max: 4)
NULLCLAW_POOL_SIZE=2

# Max concurrent containers (for per-session mode, default: 4)
NULLCLAW_MAX_CONTAINERS=4

# Base port for containers (default: 3001)
NULLCLAW_PORT=3001

# Docker image (default: latest)
NULLCLAW_IMAGE=ghcr.io/nullclaw/nullclaw:latest

# Request timeout in milliseconds (default: 300000 = 5 minutes)
NULLCLAW_TIMEOUT=300000

# Allowed domains for network egress (comma-separated)
NULLCLAW_ALLOWED_DOMAINS=openrouter.ai,api.discord.com,api.telegram.org

# Health check timeout in milliseconds (default: 30000)
NULLCLAW_HEALTH_TIMEOUT=30000

# Docker network for container communication
NULLCLAW_NETWORK=bing-network

# Workforce / multi-agent orchestration
WORKFORCE_MAX_CONCURRENCY=4
WORKFORCE_ENABLED=true

# Chat agentic routing (auto | unified | off)
CHAT_AGENTIC_PIPELINE=auto


# ===========================================
# SANDBOX / CODE EXECUTION
# ===========================================

# Sandbox provider (daytona, runloop, microsandbox, e2b, mistral-agent, blaxel, or sprites)
# mistral-agent: Uses Mistral AI Agents API with code_interpreter tool
# Required for V2 OpenCode Containerized mode
SANDBOX_PROVIDER=daytona


# Daytona API credentials
DAYTONA_API_KEY=your_daytona_api_key_here


# ===========================================
# VERCEL SANDBOX PROVIDER (NEW)
# ===========================================
# Vercel Sandbox provides isolated, ephemeral Linux VMs
# Documentation: https://vercel.com/docs/vercel-sandbox
# Features: Snapshots, firewall policies, OIDC auth
#
# Authentication (choose one):
# Option 1: Vercel Access Token (recommended for development)
#   - Generate at: https://vercel.com/account/tokens
# Option 2: VERCEL_SANDBOX_TOKEN (dedicated sandbox token)
#
# Required: At least one token must be set

VERCEL_TOKEN=your_vercel_access_token_here
# VERCEL_SANDBOX_TOKEN=your_dedicated_sandbox_token_here

# Optional: Team ID for team sandboxes
# VERCEL_TEAM_ID=your_team_id_here

# Optional: Custom API endpoint (defaults to Vercel production API)
# VERCEL_SANDBOX_API_URL=https://api.vercel.com/v1/sandbox

# Optional: Enable outbound firewall for security
# Prevents data exfiltration by restricting network access
# VERCEL_SANDBOX_FIREWALL=true

# Vercel Sandbox monthly quota (sandbox sessions)
# Adjust based on your Vercel plan and budget
# See: https://vercel.com/docs/vercel-sandbox/pricing
QUOTA_VERCEL_SANDBOX_MONTHLY=1000


# ===========================================
# RUNLOOP SANDBOX PROVIDER (NEW)
# ===========================================
RUNLOOP_API_KEY=your_runloop_api_key_here


# ===========================================
# BLAXEL SANDBOX PROVIDER (NEW)
# ===========================================
# Blaxel API credentials for sandbox provider
# Get API key from: https://console.blaxel.ai/settings/api-keys
# Documentation: https://docs.blaxel.ai/api-reference/compute/create-sandbox
# Features: Ultra-fast resume (<25ms), auto scale-to-zero, persistent volumes, VPC integration

BLAXEL_API_KEY=your_blaxel_api_key_here
BLAXEL_WORKSPACE=your_workspace_slug

# Optional: Default region for sandbox deployment
#BLAXEL_DEFAULT_REGION=us-pdx-1

# Optional: Default runtime image
#BLAXEL_DEFAULT_IMAGE=blaxel/base-image:latest

# Optional: Default memory in MB
#BLAXEL_DEFAULT_MEMORY=4096

# Optional: TTL for sandboxes (e.g., "24h", "7d")
#BLAXEL_DEFAULT_TTL=24h

# Optional: Enable VPC networking
#BLAXEL_VPC_NAME=your-vpc-name
#BLAXEL_EGRESS_GATEWAY_NAME=your-egress-gateway

# Blaxel monthly quota (sandbox sessions)
# Adjust based on your plan and budget
QUOTA_BLAXEL_MONTHLY=5000

# ===========================================
# BLAXEL ADVANCED FEATURES
# ===========================================

# Enable async execution with callbacks (default: true)
# Allows long-running tasks (up to 15 min) with webhook callbacks
BLAXEL_ASYNC_ENABLED=true

# Callback secret for webhook signature verification
# REQUIRED in production - webhook endpoint will reject requests without this
# Generate with: openssl rand -hex 32
BLAXEL_CALLBACK_SECRET=your-64-char-secret-here

# Enable log streaming (default: true)
# Real-time log streaming for monitoring and debugging
BLAXEL_LOG_STREAMING_ENABLED=true

# Enable volume templates (default: true)
# Pre-populate volumes with files for faster environment setup
BLAXEL_VOLUME_TEMPLATES_ENABLED=true

# Default volume template directory (default: /workspace)
#BLAXEL_VOLUME_TEMPLATE_DIR=/workspace

# Enable agent handoffs (default: true)
# Multi-agent orchestration via blAgent().run()
BLAXEL_AGENT_HANDOFFS_ENABLED=true

# Enable MCP server advanced tools (default: true)
# Adds stream_logs, call_agent tools to MCP server
BLAXEL_MCP_ADVANCED_TOOLS_ENABLED=true

# Mistral Agent Sandbox Provider
# Documentation: https://docs.mistral.ai/agents/
# Model for general agent tasks
MISTRAL_AGENT_MODEL=mistral-medium-2505
# Model for code interpretation
MISTRAL_CODE_INTERPRETER_MODEL=mistral-medium-2505
# Agent behavior configuration
MISTRAL_AGENT_TEMPERATURE=0.3
MISTRAL_AGENT_TOP_P=0.95
# Execution configuration
MISTRAL_CODE_EXECUTION_MAX_RETRIES=3
MISTRAL_CODE_EXECUTION_TIMEOUT_MS=120000
MISTRAL_ENABLE_STREAMING=true
MISTRAL_ENABLE_QUOTA_TRACKING=true
MISTRAL_CODE_EXECUTION_MONTHLY_QUOTA=1000



# ===========================================
# FLY.IO SPRITES PROVIDER (NEW)
# ===========================================
# Sprites API token for sandbox provider
# Generate token at: https://sprites.dev/account
# Or use CLI: sprite org auth
# Documentation: https://docs.sprites.dev/
# Features: Persistent VMs, hardware isolation, checkpoints, auto-hibernation, full Linux environment

SPRITES_TOKEN=your_sprites_api_token_here

# Optional: Default organization
#SPRITES_ORG=personal

# Optional: Default region for Sprite deployment
#SPRITES_DEFAULT_REGION=iad

# Optional: Default plan (standard-1, standard-2, performance-1, etc.)
#SPRITES_DEFAULT_PLAN=standard-1

# Optional: Enable checkpointing for stateful workloads
SPRITES_ENABLE_CHECKPOINTS=true

# Checkpoint auto-creation before dangerous operations (default: true)
#SPRITES_CHECKPOINT_AUTO_CREATE=true

# Checkpoint retention policy (default: keep 10 checkpoints, max 30 days)
#SPRITES_CHECKPOINT_MAX_COUNT=10
#SPRITES_CHECKPOINT_MAX_AGE_DAYS=30
#SPRITES_CHECKPOINT_MIN_KEEP=3

# Optional: Auto-create services for common ports
#SPRITES_AUTO_SERVICES=false

# Optional: Mount filesystem locally via SSHFS (advanced)
SPRITES_ENABLE_SSHFS=true

# Sprites monthly quota (hours of compute time)
# Sprites bill per second, free when idle, storage is separate
QUOTA_SPRITES_MONTHLY=2000

# Sandbox Provider Fallback Chain
# Comma-separated list of providers in order of preference
# When primary provider fails, automatically tries next in chain
# Example: SANDBOX_PROVIDER_FALLBACK_CHAIN=daytona,e2b,mistral-agent,runloop,microsandbox,codesandbox
SANDBOX_PROVIDER_FALLBACK_CHAIN=daytona,e2b,mistral-agent,runloop,microsandbox,sprites,codesandbox

# Enable Mistral Agent as fallback when primary providers fail
SANDBOX_ENABLE_MISTRAL_FALLBACK=true

# Optional fallback provider when primary fails (e.g. Daytona quota/memory limits)
SANDBOX_ENABLE_FALLBACK=true
SANDBOX_FALLBACK_PROVIDER=mistral-agent
# Microsandbox daemon bootstrap (used by microsandbox provider)
# Set false if you manage daemon externally
MICROSANDBOX_AUTO_START=true
# Command used by auto-start logic
MICROSANDBOX_START_COMMAND=msb server start --dev
# Wait time for daemon to become reachable
MICROSANDBOX_START_TIMEOUT_MS=20000
# Set false to disable non-sandboxed local fallback when daemon is unavailable
MICROSANDBOX_ALLOW_LOCAL_FALLBACK=true

# ===========================================
# SANDBOX SECURITY CONFIGURATION
# ===========================================
# These settings help secure the sandbox environment

# Network Egress Filtering (recommended for production)
# Restrict sandbox network access - comma-separated allowed domains/IPs
# Example: SANDBOX_ALLOWED_EGRESS=api.openai.com,api.mistral.ai,replicate.io
# Leave empty to allow all (not recommended for production)
# SANDBOX_ALLOWED_EGRESS=

# Sandbox Filesystem Isolation
# Set to true to mount workspace as read-only (except /workspace)
# SANDBOX_READONLY_FS=false

# Environment Variable Isolation  
# Set to true to prevent sandbox from accessing host environment variables
# Recommended: true (sandbox gets only explicitly passed vars)
# SANDBOX_ISOLATE_ENV=true

# Command Blocklist Mode
# LOCAL_ONLY: Only block in local shell (default)
# SANDBOX: Also block in sandbox (requires sandbox support)
# DISABLED: Turn off command blocking
# TERMINAL_SECURITY_MODE=LOCAL_ONLY

NEXT_PUBLIC_WEBCONTAINER_CLIENT_ID=webcontainer_id

# ===========================================
# BACKEND MODULES (Production)
# ===========================================

# Storage Backend Configuration
# Type: 's3' or 'local'
STORAGE_TYPE=local

# S3/MinIO Configuration (for STORAGE_TYPE=s3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ephemeral-snapshots
S3_REGION=us-east-1
S3_PREFIX=snapshots/

# Local Storage Configuration (for STORAGE_TYPE=local)
LOCAL_SNAPSHOT_DIR=/tmp/snapshots

# Container Runtime Configuration
# Type: 'auto', 'firecracker', or 'process'
RUNTIME_TYPE=auto

# Firecracker Configuration (for RUNTIME_TYPE=firecracker)
FIRECRACKER_BIN=/usr/bin/firecracker
JAILER_BIN=/usr/bin/jailer
FIRECRACKER_BASE_DIR=/tmp/firecracker

# Process Runtime Configuration (for RUNTIME_TYPE=process)
WORKSPACE_DIR=/tmp/workspaces

# WebSocket Terminal Configuration
# IMPORTANT: Must be different from Next.js HTTP port (default 3000)
# The WebSocket server runs separately from Next.js to handle real-time terminal streaming
# Next.js handles HTTP requests (port 3000), WebSocket handles bidirectional terminal I/O (port 8080)
# If port 8080 is in use, change this to another available port (e.g., 8081, 8082, etc.)
# To check if port is in use: lsof -i :8080 (Unix) or netstat -ano | findstr :8080 (Windows)
WEBSOCKET_PORT=8080

# Resource Quotas
MAX_EXECUTIONS_PER_HOUR=1000
MAX_CONCURRENT_SANDBOXES=10
MAX_MEMORY_MB=2048
MAX_STORAGE_MB=10240
MAX_CPU_CORES=4
MAX_NETWORK_EGRESS_MB=1024
QUOTA_WARNING_THRESHOLD=80


# ===========================================
# AUTHENTICATION (Required for Production)
# ===========================================

# JWT Configuration
# JWT Secret (for authentication) - SECURITY CRITICAL: JWT_SECRET MUST BE CHANGED to a cryptographically secure random secret of minimum 32 bytes/characters, must never be committed to source control, and should be generated using a secure RNG and rotated periodically. Store in a secrets manager or CI/CD secret store.
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Identity Provider Configuration
# Choose one: auth0, clerk, supabase, or keycloak
IDP_TYPE=auth0
IDP_ISSUER=https://your-domain.auth0.com/
IDP_AUDIENCE=https://your-api.com

# Identity Provider Public Key (for JWT validation)
# Get from your IdP dashboard
# For Auth0: Download from Advanced Settings → Certificates
# For Clerk: Settings → JWT Templates → Custom JWT
# For Supabase: Settings → API → JWT Secret
AUTH_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# ===========================================
# DOCKER/CONTAINER CONFIGURATION
# ===========================================

# Docker Configuration
DOCKER_ENABLED=false
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK=ephemeral-network
CONTAINER_IMAGE=ubuntu:22.04
CONTAINER_USER=1000:1000
CONTAINER_WORKDIR=/workspace

# ===========================================
# SNAPSHOT CONFIGURATION
# ===========================================

# Snapshot Directory (for local storage)
SNAPSHOT_DIR=/tmp/snapshots
WORKSPACE_DIR=/tmp/workspaces

# Snapshot Retention
SNAPSHOT_RETENTION_COUNT=5
SNAPSHOT_RETENTION_DAYS=30

# Snapshot Compression
SNAPSHOT_COMPRESSION=zstd
SNAPSHOT_COMPRESSION_LEVEL=3

# ===========================================
# PREVIEW ROUTER CONFIGURATION
# ===========================================

# Preview Router Port
PREVIEW_ROUTER_PORT=8001

# Preview Router Configuration
PREVIEW_ROUTER_FALLBACK_ENABLED=true
PREVIEW_ROUTER_HEALTH_CHECK_INTERVAL=30

# ===========================================
# BACKGROUND JOBS CONFIGURATION
# ===========================================

# Background Job Configuration
BACKGROUND_JOB_INTERVAL=5
BACKGROUND_JOB_MAX_JOBS_PER_SANDBOX=10

# ===========================================
# MONITORING & LOGGING CONFIGURATION
# ===========================================

# Logging Configuration
# Set to 'silent' to disable all logs, 'error' for errors only, 'warn' for warnings, 'info' for info, 'debug' for all
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/run.log
DEBUG_VFS=true
DEBUG_CODE_PREVIEWS=true
DEBUG_TERMINAL=true


# Prometheus Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ===========================================
# MINIO CONFIGURATION (Local Development)
# ===========================================

# MinIO Configuration (for local S3-compatible storage)***
MINIO_ENABLED=true
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CONSOLE_PORT=9001

# ===========================================
# EPHEMERAL/ PYTHON BACKEND (Legacy)
# ===========================================

# Enable legacy Python backend from ephemeral/
# Set to true if running ephemeral/ Python services
EPHEMERAL_PYTHON_ENABLED=true
EPHEMERAL_SANDBOX_API_URL=http://localhost:8000
EPHEMERAL_SNAPSHOT_API_URL=http://localhost:8002
EPHEMERAL_PREVIEW_ROUTER_URL=http://localhost:8001
EPHEMERAL_AGENT_API_URL=http://localhost:8003

# ===========================================
# SPRITES ADVANCED FEATURES
# ===========================================

# Enable tar-pipe sync for large projects (default: true)
# Syncs 10+ files using compressed tar stream (10x faster)
SPRITES_ENABLE_TAR_PIPE_SYNC=true

# Tar-pipe sync threshold (default: 10 files)
# Use tar-pipe for projects with this many files or more
SPRITES_TAR_PIPE_THRESHOLD=10

# Enable auto-suspend for Sprites (default: true)
# When enabled, Sprites save memory state on idle and resume <500ms
# Services configured with autostop=suspend preserve memory state
SPRITES_ENABLE_AUTO_SUSPEND=true

# Enable CI/CD helpers (default: true)
# Provides checkpoint-based "golden states" for CI pipelines
SPRITES_ENABLE_CI_HELPERS=true

# Default CI working directory (default: /home/sprite/repo)
#SPRITES_CI_WORKING_DIR=/home/sprite/repo

# Checkpoint auto-creation before dangerous operations (default: true)
# Automatically creates checkpoints before risky operations
SPRITES_CHECKPOINT_AUTO_CREATE=true

# Checkpoint retention policy
#SPRITES_CHECKPOINT_MAX_COUNT=10
#SPRITES_CHECKPOINT_MAX_AGE_DAYS=30
#SPRITES_CHECKPOINT_MIN_KEEP=3

# Storage quota for checkpoints (GB, default: 10)
# Used for quota tracking and warnings
#SPRITES_STORAGE_QUOTA_GB=10

# ===========================================
# ADVANCED FEATURES CONFIGURATION
# ===========================================

# -------------------------------------------
# SSHFS Mount Helper (Sprites)
# -------------------------------------------
# Enable SSHFS mounting for local filesystem access to Sprites
# Requires: SSHFS installed locally (brew install macfuse sshfs | apt-get install sshfs)
# Documentation: docs/ADVANCED_FEATURES_IMPLEMENTATION.md

# Enable SSHFS mount feature (default: true)
SPRITES_SSHFS_ENABLED=true

# Default SSH tunnel port (default: 2000)
#SPRITES_SSHFS_DEFAULT_PORT=2000

# Auto-install SSH server on Sprite (default: true)
#SPRITES_SSHFS_AUTO_INSTALL_SSH=true

# SSHFS mount options (comma-separated)
#SPRITES_SSHFS_OPTIONS=reconnect,ServerAliveInterval=15,ServerAliveCountMax=3,follow_symlinks

# Tunnel establishment timeout in milliseconds (default: 10000)
#SPRITES_SSHFS_TUNNEL_TIMEOUT=10000

# -------------------------------------------
# CodeSandbox SDK Integration
# -------------------------------------------
# Cloud VM sandboxes with preview URLs and PTY terminals
# Requires: npm install @codesandbox/sdk
# Get API key: https://codesandbox.io/docs/api-reference/authentication
# Documentation: https://codesandbox.io/docs/sdk
# Best practices: https://codesandbox.io/docs/sdk/manage-sandboxes

# Required: API key from https://codesandbox.io/t/api
CSB_API_KEY=your_codesandbox_api_key_here

# Default template for new sandboxes (node, react, nextjs, vue, python, go, rust, etc.)
#CSB_DEFAULT_TEMPLATE=node

# Sandbox privacy setting: public | private | public-hosts (default: public-hosts)
# public-hosts: Sandbox is private, but hosts/previews are publicly accessible
#CSB_PRIVACY=public-hosts

# Hibernation timeout in seconds (default: 86400 = 24 hours)
# Set to maximum and manage lifecycle manually for best cost control
#CSB_HIBERNATION_TIMEOUT=86400

# Disable automatic wakeup on HTTP/WebSocket access
# Recommended: false for manual lifecycle management
#CSB_AUTO_WAKEUP=false

# Default VM tier: micro, small (default: micro)
#CSB_VM_TIER=micro

# Enable preview URLs (https://$ID-$PORT.csb.app) - default: true
#CSB_PREVIEW_ENABLED=true

# Command timeout in milliseconds (default: 600000 = 10 minutes)
#CSB_COMMAND_TIMEOUT=600000

# Quota management (sandbox sessions per month)
QUOTA_CODESANDBOX_MONTHLY=3000

# Default mount point base directory (default: /tmp)
#SPRITES_SSHFS_MOUNT_BASE=/tmp

# -------------------------------------------
# MCP Server Integration (Blaxel)
# -------------------------------------------
# Enable MCP (Model Context Protocol) server for AI assistant integration
# Requires: @modelcontextprotocol/sdk installed (npm install @modelcontextprotocol/sdk)
# Documentation: docs/ADVANCED_FEATURES_IMPLEMENTATION.md

# Enable MCP server feature (default: true)
BLAXEL_MCP_ENABLED=true

# Default MCP server port for HTTP transport (default: 3000)
#BLAXEL_MCP_DEFAULT_PORT=3000

# MCP server endpoint path (default: /mcp)
#BLAXEL_MCP_ENDPOINT=/mcp

# Enable stdio transport (for local AI assistants like Cursor, Claude Desktop)
# Set to 'false' to only use HTTP transport
BLAXEL_MCP_STDIO_ENABLED=true

# MCP tools to enable (comma-separated, default: all)
# Options: execute_command, write_file, read_file, list_directory, 
#          get_sandbox_info, run_batch_job, execute_async
#BLAXEL_MCP_TOOLS=execute_command,write_file,read_file,list_directory,get_sandbox_info

# Enable batch job tool (requires Blaxel job deployment)
BLAXEL_MCP_ENABLE_BATCH_JOB=true

# Enable async execution tool (for long-running commands up to 15 min)
BLAXEL_MCP_ENABLE_ASYNC_EXEC=true

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
# Configure rate limits for sandbox operations to prevent abuse
# Documentation: docs/ADVANCED_FEATURES_IMPLEMENTATION.md

# Enable rate limiting (default: true)
SANDBOX_RATE_LIMITING_ENABLED=true

# Rate limit mode: 'per-user' | 'per-ip' | 'both'
#SANDBOX_RATE_LIMIT_MODE=per-user

# Commands rate limit (shell command execution)
# Default: 100 requests per minute
SANDBOX_RATE_LIMIT_COMMANDS_MAX=100
SANDBOX_RATE_LIMIT_COMMANDS_WINDOW_MS=60000

# File operations rate limit (read/write)
# Default: 50 requests per minute
SANDBOX_RATE_LIMIT_FILE_OPS_MAX=50
SANDBOX_RATE_LIMIT_FILE_OPS_WINDOW_MS=60000

# Batch jobs rate limit
# Default: 10 requests per minute
SANDBOX_RATE_LIMIT_BATCH_JOBS_MAX=10
SANDBOX_RATE_LIMIT_BATCH_JOBS_WINDOW_MS=60000

# Async execution rate limit
# Default: 20 requests per minute
SANDBOX_RATE_LIMIT_ASYNC_EXEC_MAX=20
SANDBOX_RATE_LIMIT_ASYNC_EXEC_WINDOW_MS=60000

# Checkpoints rate limit (Sprites only)
# Default: 30 requests per minute
SANDBOX_RATE_LIMIT_CHECKPOINTS_MAX=10
SANDBOX_RATE_LIMIT_CHECKPOINTS_WINDOW_MS=60000

# Proxy tunnels rate limit (Sprites only)
# Default: 5 requests per minute
SANDBOX_RATE_LIMIT_PROXY_MAX=5
SANDBOX_RATE_LIMIT_PROXY_WINDOW_MS=60000

# Rate limit error message
#SANDBOX_RATE_LIMIT_MESSAGE=Rate limit exceeded. Please slow down.

# Rate limit HTTP status code (default: 429)
#SANDBOX_RATE_LIMIT_STATUS_CODE=429

# Premium user multipliers (for tiered rate limits)
# Set these to multiply default limits for premium users
#SANDBOX_RATE_LIMIT_PREMIUM_MULTIPLIER=10
#SANDBOX_RATE_LIMIT_ENTERPRISE_MULTIPLIER=100

# -------------------------------------------
# Webhook Callback Configuration (Blaxel Async)
# -------------------------------------------
# For async execution callback verification
# Documentation: https://docs.blaxel.ai/Agents/Asynchronous-triggers

# Secret for verifying webhook callbacks (generate with: openssl rand -hex 32)
# REQUIRED in production when using async execution with callback URLs
# Without this, webhook authentication will fail and requests will be rejected
# Generate a new secret: openssl rand -hex 32
BLAXEL_CALLBACK_SECRET=your-64-char-callback-secret-here

# Callback URL for async executions (optional, can be set per-execution)
#BLAXEL_DEFAULT_CALLBACK_URL=https://your-app.com/api/callback

# -------------------------------------------
# E2B Git Integration
# -------------------------------------------
# Default depth for git clone operations (1 for fastest clone)
E2B_GIT_DEFAULT_DEPTH=1

# -------------------------------------------
# Execution Recording (Cross-Provider)
# -------------------------------------------
# Enable execution recording for deterministic replay
EXECUTION_RECORDING_ENABLED=true

# Maximum events to store per session
EXECUTION_RECORDING_MAX_EVENTS=10000

# Include read operations in recording (may contain sensitive data)
EXECUTION_RECORDING_INCLUDE_READS=false

# Include command/file outputs in recording (increases storage)
EXECUTION_RECORDING_INCLUDE_OUTPUT=true

# -------------------------------------------
# Template Building (E2B/CodeSandbox)
# -------------------------------------------
# Enable template building for custom sandbox templates
TEMPLATE_BUILDER_ENABLED=true

# Template builder provider (e2b or codesandbox)
TEMPLATE_BUILDER_PROVIDER=e2b

# Default template name prefix
#TEMPLATE_BUILDER_PREFIX=bing-

# Template build timeout (ms)
TEMPLATE_BUILDER_TIMEOUT_MS=300000

# -------------------------------------------
# MCP Gateway Integration
# -------------------------------------------
# Enable centralized MCP gateway
MCP_GATEWAY_ENABLED=true

# MCP Gateway URL (centralized tool discovery)
MCP_GATEWAY_URL=http://localhost:8261/mcp

# MCP Gateway authentication token
#MCP_GATEWAY_AUTH_TOKEN=your_mcp_gateway_bearer_token

# MCP Gateway timeout (ms)
MCP_GATEWAY_TIMEOUT_MS=50000

# Multiple MCP servers (comma-separated: name|url|token)
#MCP_SERVERS=local|http://localhost:8261/mcp,remote|https://mcp.example.com/mcp|token123

# MCP health check interval (ms)
MCP_HEALTH_CHECK_INTERVAL_MS=60000

# MCP auto-reconnect on failure
MCP_AUTO_RECONNECT=true

# Default MCP tool call timeout (ms)
MCP_DEFAULT_TIMEOUT_MS=30000

# ===========================================
# MCP CLI SERVER SECURITY
# ===========================================
# Security configuration for MCP HTTP server (port 8888)

# MCP CLI server port
MCP_CLI_PORT=8888

# MCP authentication token for CLI server
# REQUIRED in production - prevents unauthorized tool access
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=your-mcp-auth-token-change-in-production

# Allowed CORS origins (comma-separated)
# Restrict to your application domain in production
MCP_ALLOWED_ORIGINS=http://localhost:3000

# Maximum request body size (bytes) - prevents DoS
MCP_MAX_BODY_SIZE=1048576

# MCPorter integration settings
MCPORTER_ENABLED=true
MCPORTER_REFRESH_MS=30000
MCPORTER_CALL_TIMEOUT_MS=30000
MCPORTER_LIST_TIMEOUT_MS=30000

# -------------------------------------------
# Advanced Tool Calling & Optimization
# -------------------------------------------
# Enable advanced tool routing with cost optimization
ADVANCED_TOOL_ROUTING_ENABLED=true

# Optimization goal: cost, speed, quality, balanced
TOOL_ROUTING_OPTIMIZATION_GOAL=balanced

# Track tool execution metrics for optimization
TOOL_ROUTING_TRACK_METRICS=true

# Maximum cost history entries to retain
TOOL_ROUTING_MAX_COST_HISTORY=10000

# -------------------------------------------
# Template Integration (OpenCode, Claude Code)
# -------------------------------------------
# OpenCode API configuration
OPENCODE_API_KEY=your_opencode_api_key_here
#OPENCODE_BASE_URL=https://api.opencode.ai/v1

# Claude Code template configuration
CLAUDE_CODE_TEMPLATE_ENABLED=true
CLAUDE_CODE_DEFAULT_MODEL=claude-3-5-sonnet-20241022
CLAUDE_CODE_DEFAULT_MAX_TOKENS=4096
CLAUDE_CODE_DEFAULT_TEMPERATURE=0.7

# -------------------------------------------
# VFS Sync Configuration
# -------------------------------------------
# Universal VFS sync across all sandbox providers
# Documentation: docs/VERCEL_AI_SDK_FEATURES.md

# Default sync mode (full | incremental | bootstrap)
VFS_SYNC_DEFAULT_MODE=incremental

# Sync timeout in milliseconds
VFS_SYNC_TIMEOUT_MS=60000

# Enable automatic VFS sync on sandbox creation
VFS_AUTO_SYNC_ON_CREATE=true

# Blaxel Jobs configuration
BLAXEL_JOBS_ENABLED=true
BLAXEL_JOBS_DEFAULT_TIMEOUT=300000
BLAXEL_JOBS_DEFAULT_MEMORY=2048
BLAXEL_JOBS_DEFAULT_LANGUAGE=typescript

# Blaxel MCP deployment configuration
BLAXEL_MCP_DEPLOY_ENABLED=true
BLAXEL_MCP_DEPLOY_DEFAULT_RUNTIME=node

# -------------------------------------------
# Monitoring and Logging
# -------------------------------------------

# Enable detailed logging for advanced features (default: false)
ADVANCED_FEATURES_DEBUG=true

# Log SSHFS mount operations
SPRITES_SSHFS_LOG_MOUNTS=true

# Log MCP server tool invocations
BLAXEL_MCP_LOG_TOOL_CALLS=true

# Log rate limit violations
#SANDBOX_RATE_LIMIT_LOG_VIOLATIONS=true

# Rate limit metrics endpoint (optional, for monitoring)
#SANDBOX_RATE_LIMIT_METRICS_ENDPOINT=/api/metrics/rate-limits

# Sandbox configuration
SANDBOX_WARM_POOL=true
SANDBOX_WARM_POOL_SIZE=2
SANDBOX_WARM_POOL_CPU=1
SANDBOX_WARM_POOL_MEMORY=2
SANDBOX_WARM_POOL_RETRY_COOLDOWN_MS=300000
SANDBOX_PRELOAD_PACKAGES=true
SANDBOX_BASE_PACKAGES=git,curl,wget,nodejs,python3,pip
SANDBOX_EXTRA_PACKAGES_NODE=npm,yarn,pnpm
SANDBOX_EXTRA_PACKAGES_PYTHON=requests,numpy,pandas
SANDBOX_DEFAULT_CPU=1
SANDBOX_DEFAULT_MEMORY=2

# ==================================================
# PERSISTENT CACHE (Optional - speeds up sandbox creation)
# ==================================================
# Enable persistent cache volume for shared package storage
# Reduces sandbox creation time from ~10 min to ~2-3 min after first use
# Requires ~2GB storage per cache volume

# Enable/disable persistent cache (default: true for better UX)
# When enabled, all sandboxes share a persistent cache volume at /opt/cache
# This means npm/pip packages are downloaded once and reused across all sandboxes
# Significantly improves installation speed and reduces bandwidth
SANDBOX_PERSISTENT_CACHE=true

# Cache volume name (shared across all sandboxes)
SANDBOX_CACHE_VOLUME_NAME=global-package-cache

# Cache volume size (adjust based on package needs)
# Recommended: 1GB (minimal), 2GB (recommended), 4GB (optimal)
SANDBOX_CACHE_SIZE=2GB

# Pyodide package cache (for in-browser Python execution)
# When enabled, commonly used Pyodide packages are cached in IndexedDB
# Reduces Pyodide initialization time from ~30s to ~5s on subsequent loads
PYODIDE_CACHE_ENABLED=true

# Pyodide cache max size in MB (default: 500MB)
PYODIDE_CACHE_MAX_SIZE=500

# Preload common Pyodide packages (comma-separated)
# These packages will be pre-loaded when Pyodide initializes
# Common choices: numpy,pandas,matplotlib,requests
# NOTE: Use NEXT_PUBLIC_ prefix for browser access
NEXT_PUBLIC_PYODIDE_PRELOAD_PACKAGES=numpy,pandas,matplotlib,requests

# ===========================================
# E2B SANDBOX PROVIDER
# ===========================================
# E2B provides secure cloud sandbox environments for code execution
# Get your API key from: https://e2b.dev/dashboard?tab=keys
# Free tier: 1000 hours/month, 512MB RAM, 2 vCPU

# E2B API Key (required for E2B provider)
E2B_API_KEY=e2b_your_api_key_here

# Default template for E2B sandboxes
# Options: base, go, rust, java, r, cpp
E2B_DEFAULT_TEMPLATE=base

# Default timeout in milliseconds (default: 5 minutes)
E2B_DEFAULT_TIMEOUT=300000

# E2B monthly quota (sandbox sessions)
# Free tier: 1000 hours/month
# Set to 0 to disable E2B provider
QUOTA_E2B_MONTHLY=1000
QUOTA_MISTRAL_MONTHLY=2000

# ===========================================
# E2B DESKTOP (Computer Use Agent)
# ===========================================
# Desktop sandbox with Ubuntu + XFCE for GUI automation
# Requires @e2b/desktop package
# Use for computer use agents that interact with graphical interfaces

# Desktop timeout (default: 5 minutes)
E2B_DESKTOP_TIMEOUT=300000

# Default screen resolution [width, height]
E2B_DESKTOP_RESOLUTION_X=1024
E2B_DESKTOP_RESOLUTION_Y=720

# Default DPI (dots per inch)
E2B_DESKTOP_DPI=96

# Enable VNC streaming by default (for browser viewing)
E2B_DESKTOP_AUTO_STREAM=true


# ===========================================
# DAYTONA COMPUTER USE
# ===========================================

# Daytona API Key above is also used for Computer Use Service
# Computer Use configuration
DAYTONA_COMPUTER_USE_ENABLED=true
DAYTONA_COMPUTER_USE_API_BASE=https://app.daytona.io/api






# ===========================================
# TOOL INTEGRATION ROUTER (Arcade / Nango / Composio / MCP / Tambo)
# ===========================================

# Arcade API credentials (for tool execution)
#ARCADE_API_KEY=your_arcade_api_key_here
#ARCADE_USER_ID_STRATEGY=email  # email (recommended with Arcade verifier) | id
#ARCADE_CUSTOM_VERIFIER_ENABLED=false
#ARCADE_CUSTOM_VERIFIER_URL=http://localhost:3000/api/auth/arcade/custom-verifier

# Nango API credentials (alternative to Arcade)
#NANGO_API_KEY=your_nango_api_key_here
#NANGO_HOST=https://api.nango.dev

# Composio API credentials and session defaults
#COMPOSIO_API_KEY=your_composio_api_key_here
#COMPOSIO_BASE_URL=https://backend.composio.dev
# Optional: restrict router sessions to specific toolkits (comma-separated)
#COMPOSIO_DEFAULT_TOOLKITS=gmail,github,notion
# Optional: ask Composio session to manage connection/account helpers
#COMPOSIO_MANAGE_CONNECTIONS=false

# Tool provider fallback chain (left to right)
# Supported: arcade,nango,composio,mcp,tambo
TOOL_ROUTER_PROVIDER_CHAIN=arcade,nango,composio,mcp,tambo

# Structured tool-calling mode (native | grammar | xml | auto)
TOOL_CALLING_MODE=auto
TOOL_CALLING_MAX_RETRIES=3
TOOL_CALLING_VALIDATION_TIMEOUT_MS=10000
# Security default is false. Set true only if you explicitly trust content-based tool-call parsing.
TOOL_CALLING_ALLOW_CONTENT_PARSING=true



# ===========================================
# SMITHERY.AI INTEGRATION (MCP Marketplace)
# ===========================================
# Smithery API - Discover and connect to MCP servers from marketplace
# Get API key: https://smithery.ai/settings/api
# Documentation: https://smithery.ai/docs

# Required for Smithery integration
#SMITHERY_API_KEY=your_smithery_api_key_here
SMITHERY_API_BASE=https://api.smithery.ai

# Optional: Default namespace for your MCP connections
#SMITHERY_NAMESPACE=your-namespace

# Optional: Default connection ID to use
#SMITHERY_DEFAULT_CONNECTION_ID=connection-id

# Optional: Enable Smithery in tool router chain
SMITHERY_ENABLED=true

# ===========================================
# BLAXEL MCP INTEGRATION
# ===========================================
# Blaxel API - Deploy and manage MCP servers
# Get API key: https://blaxel.ai/settings/api-keys
# Documentation: https://docs.blaxel.ai

# Required for Blaxel MCP integration
#BLAXEL_API_KEY=your_blaxel_api_key_here
BLAXEL_API_BASE=https://api.blaxel.ai

# Blaxel workspace slug (required for MCP operations)
#BLAXEL_WORKSPACE=your-workspace-slug

# Optional: Blaxel MCP Server IDs (comma-separated for multiple servers)
#BLAXEL_MCP_SERVER_IDS=server-id-1,server-id-2

# Optional: Default runtime for MCP servers (node | python)
#BLAXEL_MCP_DEFAULT_RUNTIME=node

# Optional: Default region for MCP server deployment
#BLAXEL_MCP_DEFAULT_REGION=us-east-1

# Optional: Enable async triggers with callback
#BLAXEL_MCP_CALLBACK_URL=https://your-domain.com/api/blaxel/callback

# Callback secret for webhook verification - REQUIRED in production
# Generate with: openssl rand -hex 32
#BLAXEL_MCP_CALLBACK_SECRET=your-callback-secret

# Optional: Enable Blaxel MCP in tool router chain
BLAXEL_MCP_ENABLED=true

# ===========================================
# TOOL PROVIDER CHAIN (Updated Order)
# ===========================================
# Supported: arcade,nango,composio,smithery,blaxel-mcp,mcp,tambo
# Order matters: left to right fallback
TOOL_ROUTER_PROVIDER_CHAIN=arcade,nango,composio,smithery,blaxel-mcp,mcp,tambo

# ===========================================
# AUTO RUN MIGRATIONS
# ===========================================

AUTO_RUN_MIGRATIONS=true

# ===========================================
# QUOTA PERSISTENCE FALLBACK
# ===========================================
# Local file backup for quota counters when DB writes fail.
# Quotas are merged additively with DB on restart.
QUOTA_FALLBACK_FILE_PATH=data/provider-quotas.json

# ===========================================
# SKIP DATABASE INIT (for builds)
# ===========================================

# Set to 1 to skip database initialization (useful for builds/serverless)
#SKIP_DB_INIT=1

# ===========================================
# STATEFUL AGENT (2026 Architecture)
# ===========================================
# Enable the new stateful agent with Plan-Act-Verify workflow
# Default: false (uses legacy agent for backward compatibility)
USE_STATEFUL_AGENT=true

# ===========================================
# AI SDK CONFIGURATION (Vercel AI SDK)
# ===========================================

# AI SDK Provider Selection
# Options: openai, anthropic, google
# The system will use this as the preferred provider with automatic fallback
AI_SDK_PROVIDER=openai

# AI SDK Model Selection
# Generic model names that map to provider-specific models
# Examples: gpt-4o, claude-sonnet, gemini-pro
AI_SDK_MODEL=gpt-4o

# AI SDK Max Steps for multi-step agent loops
# Controls how many tool calls the agent can make in a single request
AI_SDK_MAX_STEPS=10

# AI SDK Temperature (0.0 - 2.0)
# Higher values = more creative, lower = more deterministic
AI_SDK_TEMPERATURE=0.7


# ===========================================
# TASK-SPECIFIC MODEL CONFIGURATION
# ===========================================

# Architect Model (for planning and analysis)
# Default: gpt-4o (excellent for structured thinking)
ARCHITECT_MODEL=gpt-4o
ARCHITECT_PROVIDER=openai

# Builder Model (for code generation)
# Default: gpt-4o (good all-rounder)
BUILDER_MODEL=gpt-4o
BUILDER_PROVIDER=openai

# Linter Model (for code review and error checking)
# Default: gpt-4o-mini (fast and cost-effective)
LINTER_MODEL=gpt-4o-mini
LINTER_PROVIDER=openai

# Use Multi-Model Mode
# When true, uses different models for different tasks (architect, builder, linter)
# When false, uses DEFAULT_MODEL for all tasks
USE_MULTI_MODEL=false

# ===========================================
# NANGO INTEGRATION (External Tools)
# ===========================================

# Nango Secret Key for third-party tool integrations
# Get from: https://app.nango.dev/settings
# Enables: GitHub, Slack, Notion, and 200+ other integrations
NANGO_SECRET_KEY=your_nango_secret_key_here

# ===========================================
# REDIS CONFIGURATION (for Checkpointing)
# ===========================================

# Redis URL for persistent checkpoint storage
# If not set, uses in-memory checkpointing
REDIS_URL=redis://localhost:6379

# ===========================================
# HUMAN-IN-THE-LOOP (HITL) CONFIGURATION
# ===========================================

# Enable Human-in-the-Loop approvals
# When true, requires approval for sensitive operations
ENABLE_HITL=false

# HITL Timeout in milliseconds (default: 5 minutes)
HITL_TIMEOUT=300000

# Actions that require approval (comma-separated)
# Options: delete, overwrite, execute_destructive, create_secret
# Note: This is the legacy action list - use HITL_WORKFLOW_ID for workflow-based approvals
HITL_APPROVAL_REQUIRED_ACTIONS=delete,execute_destructive,create_secret

# ===========================================
# HITL WORKFLOW CONFIGURATION (Enhanced)
# ===========================================

# Select approval workflow: default | strict | permissive
# - default: Hybrid approach (shell commands, sensitive files require approval)
# - strict: Require approval for most write operations
# - permissive: Only approve high-risk operations (.env, secrets, high-risk shell)
HITL_WORKFLOW_ID=default

# Custom workflow settings (optional - overrides default workflow rules)
# HITL_SHELL_COMMANDS_REQUIRE_APPROVAL=true
# HITL_SENSITIVE_FILES_REQUIRE_APPROVAL=true
# HITL_READ_ONLY_AUTO_APPROVE=true
# HITL_HIGH_RISK_FILES_REQUIRE_APPROVAL=true

# Workflow approvers (comma-separated user IDs for multi-approver support)
# HITL_DEFAULT_APPROVERS=user1,user2,admin

# Enforce Plan-Act-Verify workflow phases
# When true: Discovery -> Planning -> Edit -> Verify are mandatory
# Default: true
ENFORCE_PLAN_ACT_VERIFY=true

# Self-healing: Max retry attempts on syntax errors
# Default: 3
MAX_SELF_HEAL_ATTEMPTS=3

# ===========================================
# CHECKPOINTING & STATE PERSISTENCE
# ===========================================
# Redis URL for checkpoint persistence (production)
# If not set, uses in-memory checkpointer
# (Already defined in REDIS CONFIGURATION section above)

# Checkpoint TTL in seconds (default: 24 hours)
CHECKPOINT_TTL=86400


# ===========================================
# APPLYDIFF TOOL CONFIGURATION
# ===========================================
# Require exact match for apply_diff search blocks
# Prevents accidental modifications
# Default: true
APPLY_DIFF_STRICT_MODE=true


# ========================================== =
# VISUAL EDITOR - CLI INSTALLER
# ===========================================
# Configuration for the Visual Editor's CLI component installer feature
# Allows installing UI components from HeroUI, shadcn/ui, Magic UI, Aceternity UI, etc.

# Security: Bearer token for CLI install API (set to enable auth)
# Leave empty to disable auth (development only)
# Production: Set to a secure random value (e.g., openssl rand -hex 32)***
VISUAL_EDITOR_SECRET=your_vis_editor_secret

# Project Root: Only paths under this directory are allowed for CLI installs
# Production: Set to your server's project root (e.g., /srv/myapp, /var/www)***
# Development: Defaults to process.cwd() if not set
PROJECT_ROOT=

# CLI Timeout: Kill install processes after N milliseconds (default: 2 min)
VISUAL_EDITOR_CLI_TIMEOUT=120000

# ===========================================
# V2 MULTI-AGENT ARCHITECTURE
# ===========================================
# Advanced Cursor/Devin-style agent system configuration

# -------------------------------------------
# Agent Gateway Configuration
# -------------------------------------------
# Enable V2 agent gateway for session management and SSE streaming
V2_AGENT_ENABLED=true
V2_GATEWAY_URL=http://gateway:3002
V2_WORKER_URL=http://worker:3003

# Gateway settings
GATEWAY_MAX_CONCURRENT_JOBS=10
GATEWAY_JOB_TIMEOUT_MS=300000
GATEWAY_SESSION_TIMEOUT_MS=3600000

# -------------------------------------------
# Executor Worker Configuration
# -------------------------------------------
# Number of worker replicas for parallel task execution
# Higher values = more parallel tasks but more resource usage
WORKER_CONCURRENCY=4
WORKER_REPLICAS=3

# OpenCode configuration for workers
OPENCODE_MODEL=opencode/minimax-m2.5-free
OPENCODE_MAX_STEPS=15
OPENCODE_CONTAINERIZED=true

# -------------------------------------------
# Planner Worker Configuration
# -------------------------------------------
# Enable task decomposition and planning
PLANNER_ENABLED=true
PLANNER_MAX_TASKS=20

# Planner will break complex prompts into task graphs
# Example: "Build a full-stack app" → [search, create, edit, test]

# -------------------------------------------
# Background Worker Configuration
# -------------------------------------------
# Enable background indexing and file watching
BACKGROUND_WORKER_ENABLED=true

# Indexing interval in milliseconds (default: 5 minutes)
INDEX_INTERVAL_MS=300000

# Workspace root for indexing
WORKSPACE_ROOT=/workspace

# Index storage path
INDEX_PATH=/index

# -------------------------------------------
# Sandbox Pool Configuration
# -------------------------------------------
# Enable pre-warmed sandbox pool for instant code execution
SANDBOX_POOL_ENABLED=true
SANDBOX_POOL_SIZE=5
SANDBOX_IDLE_TIMEOUT=600  # seconds before idle sandbox is destroyed

# Default sandbox provider for pool
# Options: microsandbox, e2b, daytona, sprites, codesandbox
DEFAULT_SANDBOX_PROVIDER=microsandbox

# Sandbox provider API keys (configure as needed)
E2B_API_KEY=your_e2b_api_key_here
DAYTONA_API_KEY=your_daytona_api_key_here
SPRITES_TOKEN=your_sprites_token_here
CODESANDBOX_API_KEY=your_codesandbox_api_key_here

# -------------------------------------------
# Vector Search (Qdrant)
# -------------------------------------------
# Qdrant vector database for code embeddings and semantic search
QDRANT_URL=http://qdrant:6333
QDRANT_GRPC_PORT=6334
VECTOR_SEARCH_ENABLED=true

# Embedding model (for future integration)
# Options: all-MiniLM-L6-v2 (384 dim), text-embedding-3-small (1536 dim)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# -------------------------------------------
# Execution Policies
# -------------------------------------------
# Default execution policy for tasks
# Options: local-safe, sandbox-required, sandbox-preferred, sandbox-heavy, persistent-sandbox, desktop-required
DEFAULT_EXECUTION_POLICY=local-safe

# Policy overrides for specific task types
# CODING_EXECUTION_POLICY=sandbox-required
# AUTOMATION_EXECUTION_POLICY=sandbox-preferred
# GUI_EXECUTION_POLICY=desktop-required

# -------------------------------------------
# Traefik Reverse Proxy
# -------------------------------------------
# Traefik dashboard credentials (optional)
# TRAEFIK_DASHBOARD_USER=admin
# TRAEFIK_DASHBOARD_PASSWORD=secure_password

# SSL configuration (production)
# TRAEFIK_SSL_ENABLED=true
# TRAEFIK_SSL_CERT_PATH=/ssl/cert.pem
# TRAEFIK_SSL_KEY_PATH=/ssl/key.pem

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL database for sessions, jobs, and metadata

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/binG
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT_MS=5000

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# Redis for job queue, PubSub, and caching

REDIS_URL=redis://redis:6379
REDIS_PASSWORD=  # Optional: set for production
REDIS_DB=0

# Job queue settings
QUEUE_CONCURRENCY=10
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_MS=1000

# PubSub channels
PUBSUB_JOBS_CHANNEL=jobs
PUBSUB_EVENTS_CHANNEL=events

# ===========================================
# NULLCLAW AUTOMATION
# ===========================================
# Nullclaw for Discord, Telegram, browse, and automation

NULLCLAW_ENABLED=true
NULLCLAW_URL=http://nullclaw:3000
NULLCLAW_API_KEY=  # Optional: for authenticated access
NULLCLAW_MODE=shared  # shared or dedicated

# Nullclaw automation settings
NULLCLAW_TIMEOUT=3600
NULLCLAW_ALLOWED_DOMAINS=openrouter.ai,api.discord.com,api.telegram.org

# Discord integration
DISCORD_BOT_TOKEN=  # Optional
DISCORD_CHANNEL_ID=  # Optional

# Telegram integration
TELEGRAM_BOT_TOKEN=  # Optional

# ===========================================
# MCP (Model Context Protocol)
# ===========================================
# MCP server for filesystem, memory, and tools

MCP_ENABLED=true
MCP_CLI_PORT=8888
MCP_SERVER_URL=http://mcp:8888

# MCP workspace configuration
WORKSPACE_ROOT=/workspace
VFS_ROOT=/workspace/vfs

# ===========================================
# MONITORING & OBSERVABILITY
# ===========================================
# Optional: Integrate with monitoring services

# OpenTelemetry
#OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
#OTEL_SERVICE_NAME=bing-agent

# Langfuse (LLM observability)
#LANGFUSE_PUBLIC_KEY=
#LANGFUSE_SECRET_KEY=
#LANGFUSE_HOST=https://cloud.langfuse.com

# Helicone (LLM gateway & analytics)
#HELICONE_API_KEY=

# ===========================================
# PERFORMANCE TUNING
# ===========================================
# Advanced performance settings

# Request deduplication
REQUEST_DEDUPLICATION_ENABLED=true
REQUEST_DEDUPLICATION_TTL_MS=5000

# Circuit breaker settings
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_MS=30000
CIRCUIT_BREAKER_FAILURE_WINDOW_MS=60000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_TTL_MS=300000
CACHE_MAX_SIZE=1000

# ===========================================
# SECURITY
# ===========================================
# Security-related configuration

# CORS configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5555
CORS_CREDENTIALS=true

# Helmet security headers
HELMET_ENABLED=true

# Rate limiting for API
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# DEVELOPMENT
# ===========================================
# Development-specific settings

NODE_ENV=development
DEBUG=*
LOG_LEVEL=debug

# Enable hot reload
HOT_RELOAD=true

# Skip TLS verification (development only)
NODE_TLS_REJECT_UNAUTHORIZED=0
# Increase for slow networks or large component installs
CLI_TIMEOUT_MS=120000


#SESSION_HASH_SECRET   ***
SESSION_HASH_SECRET=your_SESSION_HASH_SECRET

# ===========================================
# V2 AGENT SERVICES (NEW)
# ===========================================
# Agent Gateway, Worker, and Git-Backed VFS configuration

# Gateway Configuration
V2_GATEWAY_ENABLED=true
V2_GATEWAY_PORT=3002
V2_GATEWAY_URL=http://gateway:3002
JOB_TIMEOUT_MS=300000          # 5 minutes
SESSION_TIMEOUT_MS=3600000     # 1 hour
MAX_CONCURRENT_JOBS=10

# Worker Configuration
V2_WORKER_ENABLED=true
V2_WORKER_PORT=3003
V2_WORKER_URL=http://worker:3003
WORKER_CONCURRENCY=4           # Jobs per worker
WORKER_REPLICAS=3              # Number of worker instances
OPENCODE_MODEL=opencode/minimax-m2.5-free
OPENCODE_MAX_STEPS=15
OPENCODE_CONTAINERIZED=true

# Planner Worker (task decomposition)
PLANNER_ENABLED=true
PLANNER_PORT=3004
PLANNER_MAX_TASKS=20

# Background Worker (indexing, file watching)
BACKGROUND_WORKER_ENABLED=true
BACKGROUND_WORKER_PORT=3006
INDEX_INTERVAL_MS=300000       # 5 minutes
WORKSPACE_ROOT=/workspace
INDEX_PATH=/index

# Redis Stream for event persistence
REDIS_STREAM_KEY=agent:events

# ===========================================
# GIT-BACKED VFS (NEW)
# ===========================================
# Automatic git commits for VFS operations

GIT_VFS_AUTO_COMMIT=true       # Auto-commit on every VFS write
GIT_VFS_SESSION_ID=default     # Default session for shadow commits
GIT_VFS_ENABLE_SHADOW_COMMITS=true
GIT_VFS_COMMIT_MESSAGE=VFS auto-commit

# Shadow Commit Configuration
SHADOW_COMMIT_STORAGE=database  # or 'filesystem'
SHADOW_COMMIT_MAX_HISTORY=100
SHADOW_COMMIT_TTL=604800       # 7 days in seconds

# Rollback Configuration
ROLLBACK_ENABLED=true
ROLLBACK_MAX_VERSIONS=50
ROLLBACK_ON_ERROR=true         # Auto-rollback on agent error

# ===========================================
# SANDBOX POOL (NEW)
# ===========================================
# Pre-warmed sandbox pool for instant execution

SANDBOX_POOL_ENABLED=true
SANDBOX_POOL_SIZE=5            # Number of pre-warmed sandboxes
SANDBOX_IDLE_TIMEOUT=600       # Seconds before idle sandbox destroyed
DEFAULT_SANDBOX_PROVIDER=microsandbox

# Sandbox Provider API Keys
E2B_API_KEY=your_e2b_api_key_here
DAYTONA_API_KEY=your_daytona_api_key_here
SPRITES_TOKEN=your_sprites_token_here
CODESANDBOX_API_KEY=your_codesandbox_api_key_here
MICROSANDBOX_ENABLED=true
