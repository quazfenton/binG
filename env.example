# ===========================================
# POSTGRESQL DATABASE (For Mastra Workflows)
# ===========================================
# PostgreSQL is required for Mastra workflow engine (suspend/resume, state management)
# The app uses SQLite for user data (accounts, API keys, conversations)
# Mastra uses PostgreSQL for workflow state persistence

# PostgreSQL Connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Docker default: postgresql://bing:bing_secure_password_change_me@postgres:5432/bing
DATABASE_URL=postgresql://bing:your_secure_db_password@postgres:5432/bing

# PostgreSQL Docker Configuration
# These are used by docker-compose.yml to configure the PostgreSQL container
POSTGRES_USER=bing
POSTGRES_PASSWORD=your_secure_db_password_change_me
POSTGRES_DB=bing

# For local development without Docker, install PostgreSQL and set:
# DATABASE_URL=postgresql://localhost:5432/bing

# Mastra-specific PostgreSQL settings
# MASTRA_STORAGE_URL=postgresql://...  # Override DATABASE_URL for Mastra only
MASTRA_SCHEMA=mastra  # Schema name for multi-tenant isolation

# ===========================================
# CLOUD & DEPLOYMENT
# ===========================================

# DigitalOcean VPS deployment
DIGITALOCEAN_API_TOKEN=your_digitalocean_api_token

# Cloudflare Workers
CLOUDFLARE_WORKER_URL=https://your-worker.your-subdomain.workers.dev
WORKER_AUTH_TOKEN=your_worker_auth_token

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

