# ===========================================
# LLM PROVIDERS
# ===========================================


# OpenRouter (recommended - access to multiple models)
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here


# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here
#MISTRAL_BASE_URL=https://api.mistral.ai/v1


# GitHub Models (via Azure)
GITHUB_MODELS_API_KEY=your_github_models_api_key_here
#GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com


# ===========================================
# LLM PROVIDERS
# ===========================================

# OpenCode API (Zen and Kimi 2.5)
# V1: Cloud API mode - uses OpenCode API endpoints
OPENCODE_API_KEY=your_opencode_api_key_here
#OPENCODE_BASE_URL=https://api.opencode.ai/v1

# V2: Locally Hosted OpenCode (Containerized)
# Set LLM_PROVIDER=opencode and OPENCODE_CONTAINERIZED=true to use V2 mode
# Requires opencode CLI installed locally or in sandbox
OPENCODE_MODEL=opencode/minimax-m2.5-free  # Model to use with OpenCode CLI
OPENCODE_CONTAINERIZED=true  # Set to 'true' to run OpenCode in sandbox
#OPENCODE_SESSION_ID=  # Optional: persistent session ID
OPENCODE_BIN=opencode  # Optional: custom path to opencode binary

# V3: OpenCode SDK (Local Instance Control)
# Uses @opencode-ai/sdk to control a local OpenCode server instance
# This allows direct programmatic control of OpenCode as an LLM provider
# The SDK starts a local OpenCode server and communicates via HTTP
# 
# Configuration:
# - OPENCODE_HOSTNAME: Server hostname (default: 127.0.0.1)
# - OPENCODE_PORT: Server port (default: 4096)
# - Model is still specified via OPENCODE_MODEL above
#
# Usage:
# 1. Set OPENCODE_HOSTNAME and OPENCODE_PORT below
# 2. Use provider: 'opencode' in llm-providers.ts
# 3. SDK will auto-start local OpenCode server on first request
# 4. Server runs locally and is controlled via SDK
#
# Example:
# OPENCODE_HOSTNAME=127.0.0.1
# OPENCODE_PORT=4096
# Then use: await llmService.generateResponse({ provider: 'opencode', ... })
#
OPENCODE_HOSTNAME=127.0.0.1  # SDK: Local OpenCode server hostname
OPENCODE_PORT=4096          # SDK: Local OpenCode server port





# OpenAI (optional - OpenRouter recommended)
#OPENAI_API_KEY=sk-your_openai_api_key_here
#OPENAI_BASE_URL=https://openrouter.ai/api/v1

#AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
#AZURE_BASE_URL=https://models.inference.ai.azure.com

# Anthropic Claude
#ANTHROPIC_API_KEY=your_anthropic_api_key_here
#ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Cohere
#COHERE_API_KEY=your_cohere_api_key_here

# Together AI
#TOGETHER_API_KEY=your_together_api_key_here


# ===========================================
# IMAGE GENERATION
# ===========================================
# Multiple providers supported with automatic fallback
# Default chain: Mistral -> Replicate

# Mistral AI (Default - uses Agents API with FLUX1.1 Ultra)
# Get API key from: https://console.mistral.ai/api-keys/
# Documentation: https://docs.mistral.ai/agents/tools/built-in/image_generation
MISTRAL_API_KEY=your_mistral_api_key_here
#MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Replicate (Fallback - SDXL, Flux, Stable Diffusion models)
# Get API token from: https://replicate.com/account/api-tokens
# Documentation: https://replicate.com/docs
#REPLICATE_API_TOKEN=your_replicate_api_token_here

# Image Generation Settings
# Default provider chain (comma-separated, first available is used)
IMAGE_GENERATION_PROVIDERS=mistral,replicate
# Default quality preset: low, medium, high, ultra
IMAGE_GENERATION_DEFAULT_QUALITY=high
# Default aspect ratio: 1:1, 16:9, 9:16, 4:3, 3:2, 2:3, 21:9
IMAGE_GENERATION_DEFAULT_ASPECT_RATIO=1:1
# Generation timeout in milliseconds
#IMAGE_GENERATION_TIMEOUT_MS=120000

# Portkey AI Gateway
#PORTKEY_API_KEY=your_portkey_api_key_here
#PORTKEY_BASE_URL=https://api.portkey.ai/v1

# Chutes AI
#CHUTES_API_KEY=your_chutes_api_key_here
#CHUTES_BASE_URL=https://llm.chutes.ai/v1



# Modal (Data Science Workbench ML training backend)
#MODAL_TRAINING_URL=https://your-modal-app.modal.run/train
MODAL_API_TOKEN=your_modal_token_here



# ===========================================
# EMAIL VERIFICATION
# ===========================================

# Email Provider Selection (toggle-able)
# Options: brevo | mailersend | resend | sendgrid | smtp | auto
# - 'auto': Automatically selects first available provider (priority: brevo > mailersend > resend > sendgrid > smtp)
# - Explicit provider: Forces use of specific provider even if others are configured
EMAIL_PROVIDER=auto

# ===========================================
# BREVO (Recommended - Transactional Email API)
# ===========================================
# Get your API key from https://app.brevo.com/settings/keys/api
# Brevo offers both API and SMTP relay options:
# Quota: 300 emails/day (9000/month) free tier

# Option 1: Brevo API (recommended - full features)
BREVO_API_KEY=your_brevo_api_key_here

# Option 2: Brevo SMTP Relay (alternative)
# SMTP credentials from https://app.brevo.com/settings/smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
#SMTP_SECURE=false
SMTP_USER=a2dd32001@smtp-brevo.com
SMTP_PASS=your_brevo_smtp_password_here

# ===========================================
# MAILERSEND (Alternative - 100 emails/day)
# ===========================================
# Get your API key from https://www.mailersend.com/account/api
# Quota: 100 emails/day (3000/month) free tier
# Great alternative or fallback to Brevo

MAILERSEND_API_KEY=your_mailersend_api_key_here

# ===========================================
# RESEND (Alternative - Simplest Setup)
# ===========================================
# Get your API key from https://resend.com
#RESEND_API_KEY=re_your_resend_api_key_here

# ===========================================
# SENDGRID (Alternative)
# ===========================================
# Get your API key from https://sendgrid.com
#SENDGRID_API_KEY=your_sendgrid_api_key_here

# ===========================================
# SMTP (Generic - Works with any SMTP server)
# ===========================================
# Use with Brevo SMTP Relay, Gmail, or any SMTP server
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=your_smtp_username
#SMTP_PASS=your_smtp_password

# ===========================================
# EMAIL SETTINGS (Common)
# ===========================================

# Default: Uses Brevo's default sender (noreply@<your-account>.brevo.com)
# Replace 'your-account' with your actual Brevo account subdomain
# Find it in Brevo dashboard: https://app.brevo.com/settings/senders
EMAIL_FROM=noreply@your-account.brevo.com

# To use custom domain instead:
# 1. Verify your domain in Brevo dashboard: https://app.brevo.com/settings/senders
# 2. Add DNS records (SPF, DKIM) as instructed by Brevo
# 3. Once verified, set EMAIL_FROM to your verified address (e.g., noreply@yourdomain.com)
# EMAIL_FROM=noreply@yourdomain.com

# Sender name shown in emails
EMAIL_FROM_NAME=binG

# Email verification settings ***
REQUIRE_EMAIL_VERIFICATION=false  # Set to 'true' to block login until email is verified

APP_NAME=binG0

# ===========================================
# TASK-SPECIFIC PROVIDERS (Optional)
# ===========================================
# Use different providers optimized for specific tasks
# Leave empty to use DEFAULT_LLM_PROVIDER

#CHAT_PROVIDER=  # Chat completions (default: openrouter)
#CODE_PROVIDER=  # Code generation/review (default: openrouter)
#EMBEDDING_PROVIDER=mistral  # Embeddings (mistral-embed is excellent)
#IMAGE_PROVIDER=  # Image analysis/generation
#TOOL_PROVIDER=  # Tool/function calling
#TOOL_HANDLER=auto  # Tool service routing preference: auto | composio-tools | tool-execution
#AGENT_PROVIDER=mistral  # Agent completions (Mistral has great agent support)
#OCR_PROVIDER=mistral  # OCR processing (Mistral has OCR API)



# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Default LLM settings
DEFAULT_LLM_PROVIDER=mistral  # Default provider
DEFAULT_MODEL=mistral-large-latest  # Default model
DEFAULT_TEMPERATURE=0.7  # Creativity (0.0 - 2.0)
DEFAULT_MAX_TOKENS=80000  # Response length limit


# Development Email Logging
# In development mode (NODE_ENV=development), email verification and password reset links
# are automatically logged to console for easy testing without sending actual emails
# This is enabled by default in development and disabled in production
# No configuration needed - just check your terminal/console after triggering emails


#Terminal Sandbox connection attempt timeout before defaulting to nonPty simuluated command mode
NEXT_PUBLIC_TERMINAL_CONNECTION_TIMEOUT_MS=15000    #defaults to 15s if unset

# ===========================================
# TERMINAL SECURITY CONFIGURATION
# ===========================================
# These settings control terminal security, rate limiting, and resource management

# WebSocket configuration
# IMPORTANT: Must be different from Next.js HTTP port (default 3000)
# The WebSocket server runs separately to handle real-time terminal streaming
WEBSOCKET_PORT=8080
WEBSOCKET_PROTOCOL=ws
WEBSOCKET_HOST=localhost:8080

# Terminal security limits
# Maximum input size per command (bytes) - prevents buffer overflow attacks
TERMINAL_MAX_INPUT_SIZE=10240

# Maximum command buffer size (bytes) - prevents memory exhaustion
TERMINAL_MAX_BUFFER_SIZE=10240

# Maximum WebSocket message size (bytes)
TERMINAL_MAX_WEBSOCKET_MESSAGE_SIZE=10240

# Rate limiting: Maximum commands per second per user
# Reduced from 10 to 5 for better DoS protection
TERMINAL_MAX_COMMANDS_PER_SECOND=5

# Maximum concurrent terminal sessions per user
TERMINAL_MAX_SESSIONS_PER_USER=3

# Maximum reconnection attempts for WebSocket
TERMINAL_MAX_RECONNECT_ATTEMPTS=5

# Terminal timeouts (milliseconds)
# Connection timeout - how long to wait for PTY connection
TERMINAL_CONNECTION_TIMEOUT_MS=30000

# Idle timeout - disconnect after this period of inactivity (30 minutes)
TERMINAL_IDLE_TIMEOUT_MS=1800000

# Rate limiting for sandbox creation (per minute)
# Prevents resource exhaustion from rapid sandbox creation
SANDBOX_CREATION_RATE_LIMIT=3

# Rate limiting for WebSocket connections (per minute)
WEBSOCKET_CONNECTION_RATE_LIMIT=10

# Terminal security features
# Enable obfuscation detection (base64, hex, unicode, etc.)
TERMINAL_ENABLE_OBFUSCATION_DETECTION=true

# Block commands with detected obfuscation (default: false - just warn)
# Set to true for stricter security (may cause false positives)
TERMINAL_BLOCK_ON_OBFUSCATION=false

# Log blocked commands (truncated to prevent secret exposure)
TERMINAL_LOG_BLOCKED_COMMANDS=true

# Log connection/disconnection events
TERMINAL_LOG_CONNECTION_EVENTS=false

# Log individual command execution
TERMINAL_LOG_COMMAND_EXECUTION=false

# Log level for terminal module (debug, info, warn, error)
TERMINAL_LOG_LEVEL=info

# Session persistence
# Session TTL in milliseconds (4 hours default)
TERMINAL_SESSION_TTL_MS=14400000

# Enable cleanup of expired sessions
TERMINAL_CLEANUP_EXPIRED_SESSIONS=true

# Sandbox idle timeout (milliseconds)
# Auto-disconnect sandbox after period of inactivity
SANDBOX_IDLE_TIMEOUT_MS=900000

# Show warning before idle timeout (milliseconds)
SANDBOX_IDLE_WARNING_MS=60000


# ===========================================
# LANGRAPH & MODERN AGENTIC ARCHITECTURE
# ===========================================

# Enable LangGraph orchestration (default: false - uses custom orchestration)
# When enabled, uses LangGraph graph-based workflows instead of custom loop
USE_LANGGRAPH=false

# LangSmith Observability (optional - for production debugging)
# Get API key from: https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=bing-agents
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Model Routing (optional - cost optimization)
# Automatically route tasks to optimal model based on complexity
ENABLE_MODEL_ROUTING=false

# Model tier configuration
FAST_MODEL=mistral-large-small              # For simple tasks ($0.15/1M tokens)
REASONING_MODEL=mistral-large-latest              # For complex reasoning ($2.50/1M tokens)
CODER_MODEL=mistral-large-latest # For code tasks ($3.00/1M tokens)

# MCP Tool Server (optional - expose tools to any LLM)
# Allows Claude, GPT, Gemini to use binG tools via MCP protocol
ENABLE_MCP_TOOL_SERVER=true
MCP_TOOL_SERVER_PORT=3002

# Multi-Agent Roles (optional - specialized agents)
# Different agents for different tasks
ENABLE_MULTI_AGENT=true
PLANNER_MODEL=mistral-large-latest               # Planning agent
EXECUTOR_MODEL=gemini-3-flash # Execution agent
CRITIC_MODEL=mistral-large-latest           # Verification agent

# ===========================================
# MASTRA WORKFLOW ENGINE
# ===========================================

# Enable Mastra telemetry (default: false)
MASTRA_TELEMETRY_ENABLED=true

# Mastra Storage Configuration
# By default, Mastra uses the DATABASE_URL below
# Override with custom PostgreSQL connection if needed
# MASTRA_STORAGE_URL=postgresql://...

# Mastra Schema (for multi-tenant isolation)
MASTRA_SCHEMA=mastra

# Workflow configuration
MASTRA_MAX_STEPS=10
MASTRA_ENABLE_SUSPEND_RESUME=true

# Mastra Memory Integration (Optional)
# Enable conversation history and context management
# Note: Chat UI already has conversation history - this is for agent context
MASTRA_MEMORY_ENABLED=true
MASTRA_MEMORY_MAX_MESSAGES=100
MASTRA_MEMORY_WORKING=true
MASTRA_MEMORY_SEMANTIC=false

# Mastra Evals & Scorers (Optional)
# Enable automated code quality measurement
MASTRA_EVALS_ENABLED=true
MASTRA_EVALS_MIN_QUALITY=7
MASTRA_EVALS_MIN_SECURITY=8
MASTRA_EVALS_AUTO_REJECT=true

# ===========================================
# COMPOSIO MCP
# ===========================================

# MCP Server configuration
COMPOSIO_ENABLED=true
COMPOSIO_MCP_ENABLED=true
COMPOSIO_MCP_PORT=3001
COMPOSIO_MCP_SERVER_NAME=composio-tools
COMPOSIO_MCP_SERVER_VERSION=1.0.0

# Enable CrewAI orchestration (default: false - uses custom orchestration)
# When enabled, uses CrewAI role-based agents instead of single agent
USE_CREWAI=true

# CrewAI configuration
CREWAI_DEFAULT_PROCESS=sequential  # sequential | hierarchical | consensual
CREWAI_VERBOSE=true
CREWAI_MEMORY=true
CREWAI_CACHE=true
CREWAI_MAX_RPM=30

# Agent configuration file path
CREWAI_AGENTS_CONFIG=src/config/agents.yaml

# Process orchestration LLM (for hierarchical process)
CREWAI_PROCESS_LLM=gemini-2.5-flash
CREWAI_PLANNER_AGENT=planner
CREWAI_CODER_AGENT=coder
CREWAI_CRITIC_AGENT=critic
CREWAI_MANAGER_AGENT=manager
CREWAI_TRACING_ENABLED=true
#CREWAI_LOG_FILE=./logs/crewai.log

# Feature flags
ENABLE_VOICE_FEATURES=true  # Voice integration
ENABLE_IMAGE_GENERATION=true  # Image generation features
ENABLE_CHAT_HISTORY=true  # Chat history persistence
ENABLE_CODE_EXECUTION=true  # Code execution capabilities

# Application settings
NODE_ENV=development  # development, production
PORT=3000  # Server port
# Optional: explicit dev auth bypass (default is OFF)
NEXT_PUBLIC_SKIP_AUTH_IN_DEV=false


