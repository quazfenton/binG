  .description('Connect an OAuth integration')
  .action(async (provider) => {
    try {
      const result = await apiRequest(`/integrations/${provider}/oauth/authorize`, {
        method: 'GET',
      });
      
      console.log(COLORS.primary('\nOAuth Authorization:'));
      console.log(`\nPlease visit the following URL to connect your ${provider} account:`);
      console.log(COLORS.info(result.authUrl));
      console.log('\nAfter authorization, you will be redirected back.');
      
    } catch (error: any) {
      console.log(COLORS.error(`Error: ${error.message}`));
      process.exit(1);
    }
  });

