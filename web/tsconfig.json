{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@bing/platform": ["../packages/platform/src/env.ts"],
      "@bing/platform/*": ["../packages/platform/src/*"],
      "@bing/shared": ["../packages/shared/index.ts"],
      "@bing/shared/*": ["../packages/shared/*"],
      "@bing/shared/agent": ["../packages/shared/agent/index.ts"],
      "@bing/shared/agent/*": ["../packages/shared/agent/*"],
      "@bing/infra/*": ["../infra/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "downlevelIteration": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "deprecated",
    "__tests__",
    "docs",
    "examples",
    "scripts",
    "registry_original_backup.ts",
    "enhanced-code-system",
    "desktop",
    "tauri"
  ]
}
