{
  "name": "agent-gateway",
  "version": "1.0.0",
  "description": "Agent Gateway - Session management + SSE streaming + job queue",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "fastify": "^5.8.1",
    "@fastify/cors": "^11.1.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.0",
    "pino": "^8.17.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  }
}
