{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Quaz Desktop",
  "version": "0.1.0",
  "identifier": "com.quaz.desktop",
  "build": {
    "beforeDevCommand": "cd ../web && pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../web && pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Creator workspace",
    "longDescription": "Quaz Desktop - Workspace for creators, developers, & agents for software, automation, cloud storage, sandboxes and code execution",
    "icon": [
      "icons/favicon.ico"
    ],
    "resources": []
  }
}
